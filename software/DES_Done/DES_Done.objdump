void hex_to_string_16char(unsigned int high, unsigned int low, char *buf) { char hex[] = "0123456789ABCDEF"; int i; for(i = 0; i < 8; i++) { buf[7 - i] = hex[high & 0xF]; high >>= 4; } for(i = 0; i < 8; i++) { buf[15 - i] = hex[low & 0xF]; low >>= 4; } buf[16] = 0; }
